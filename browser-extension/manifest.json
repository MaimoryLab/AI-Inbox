{
  "manifest_version": 3,
  "name": "Agent Memory Lab",
  "short_name": "Memory Lab",
  "version": "0.1.0",
  "description": "自动抓取网页 AI 会话，并同步到本地 Agent Memory Lab 工作台。",
  "action": {
    "default_title": "Agent Memory Lab",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "permissions": ["activeTab", "alarms", "contextMenus", "sidePanel", "scripting", "storage", "tabs"],
  "host_permissions": ["http://localhost:3111/*", "http://127.0.0.1:3111/*", "http://localhost:3114/*", "http://127.0.0.1:3114/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
