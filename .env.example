# AI-Inbox local configuration example
AI_INBOX_CODEX_HOME=~/.codex
AI_INBOX_CLAUDE_HOME=~/.claude/projects
AI_INBOX_CURSOR_HOME=~/.cursor/projects
AI_INBOX_LLM_ENABLED=true
AI_INBOX_LLM_PROVIDER=openai
AI_INBOX_LLM_MODEL=deepseek/deepseek-v4-flash
AI_INBOX_LLM_ENDPOINT=https://api.novita.ai/openai/v1
AI_INBOX_LLM_THINKING_DEPTH=low
AI_INBOX_LLM_TIMEOUT_MS=120000
AI_INBOX_ORGANIZE_SINCE_DAYS=7
AI_INBOX_ORGANIZE_MAX_INTERACTIONS_PER_SESSION=10
AI_INBOX_ORGANIZE_MAX_SESSIONS=16
AI_INBOX_ORGANIZE_MAX_OBSERVATIONS_PER_SESSION=40

# Release zips may include a managed key injected by CI. Set this only to override it.
# AI_INBOX_LLM_API_KEY=
