# AI-Index local configuration example
AI_INDEX_CODEX_HOME=~/.codex
AI_INDEX_CLAUDE_HOME=~/.claude/projects
AI_INDEX_LLM_ENABLED=true
AI_INDEX_LLM_PROVIDER=openai
AI_INDEX_LLM_MODEL=deepseek/deepseek-v4-flash
AI_INDEX_LLM_ENDPOINT=https://api.novita.ai/openai/v1
AI_INDEX_LLM_THINKING_DEPTH=medium
AI_INDEX_LLM_TIMEOUT_MS=120000
AI_INDEX_ORGANIZE_SINCE_DAYS=7
AI_INDEX_ORGANIZE_MAX_INTERACTIONS_PER_SESSION=10
AI_INDEX_ORGANIZE_MAX_SESSIONS=16
AI_INDEX_ORGANIZE_MAX_OBSERVATIONS_PER_SESSION=40

# Do not commit real keys. Run `ai-index init --api-key ...` or save in Settings.
# AI_INDEX_LLM_API_KEY=
